# ============================================================
# PLAY16 — Variables d'environnement (BOOT INITIAL UNIQUEMENT)
# ============================================================
# Règle d'or : aucun secret de service externe ici (Campay, Twilio,
# WhatsApp, etc.) — ceux-là vivent dans settings_integrations (DB),
# configurables à chaud depuis Super Admin > Intégrations.
#
# Ce fichier ne contient QUE ce qui est nécessaire pour démarrer
# le serveur lui-même (connexion DB, secrets internes JWT).
# ============================================================

# Fourni automatiquement par Railway lors du provisioning PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/database

# Secret interne pour signer les tokens de session (générer une
# longue chaîne aléatoire, jamais la même qu'un secret de provider)
JWT_SECRET=change_me_generate_a_long_random_string

# Port d'écoute (Railway le fournit automatiquement en prod)
PORT=3000

# Environnement
NODE_ENV=development
